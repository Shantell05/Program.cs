<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" 
        Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="800">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII Art Header - Reduced Height -->
        <Border Grid.Row="0" 
                Background="#0A2E5C" 
                Padding="10" 
                Margin="0,0,0,10">
            <ScrollViewer x:Name="AsciiArtScrollViewer" 
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Disabled" 
                          MaxHeight="140">
                <TextBlock x:Name="AsciiArtTextBlock" 
                           FontFamily="Consolas" 
                           FontSize="9" 
                           Foreground="#00D4FF"
                           TextWrapping="NoWrap"/>
            </ScrollViewer>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="1" 
                Background="#2D2D2D" 
                Padding="12" 
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText" 
                           Text="Ready" 
                           Foreground="#51CF66" 
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1" 
                        Background="#1E1E1E" 
                        Padding="10,5" 
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SentimentEmoji" Text="😐" FontSize="14"/>
                        <TextBlock x:Name="SentimentText" Text="Neutral" Foreground="#888888" FontSize="12" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>

                <Button x:Name="StatsButton" 
                        Grid.Column="2"
                        Content="Stats" 
                        Width="70" 
                        Height="30"
                        Click="StatsButton_Click"
                        Background="#0A2E5C"
                        Foreground="White"
                        BorderBrush="#00D4FF"
                        BorderThickness="1"
                        Cursor="Hand"/>

                <Button x:Name="ExitButton" 
                        Grid.Column="3"
                        Content="Exit" 
                        Width="70" 
                        Height="30"
                        Margin="10,0,0,0"
                        Click="ExitButton_Click"
                        Background="#8B0000"
                        Foreground="White"
                        BorderBrush="#FF4444"
                        BorderThickness="1"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Name Input Panel -->
        <Border x:Name="NameInputPanel" 
                Grid.Row="2" 
                Background="#0A2E5C" 
                Padding="15" 
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Your Name:" 
                           Foreground="White" 
                           FontSize="14" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>

                <TextBox x:Name="NameTextBox" 
                         Grid.Column="1"
                         Background="#1E1E1E" 
                         Foreground="White" 
                         BorderBrush="#00D4FF" 
                         BorderThickness="1" 
                         Padding="12"
                         FontSize="14"
                         VerticalContentAlignment="Center"/>

                <Button x:Name="SaveNameButton" 
                        Grid.Column="2"
                        Content="Start Chat" 
                        Width="100" 
                        Height="40"
                        Margin="10,0,0,0"
                        Click="SaveNameButton_Click"
                        Background="#1A5F7A"
                        Foreground="White"
                        BorderBrush="#00D4FF"
                        BorderThickness="1"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Chat Messages Area -->
        <ScrollViewer x:Name="ChatScrollViewer" 
                      Grid.Row="3" 
                      Background="#252525"
                      BorderBrush="#0A2E5C" 
                      BorderThickness="2"
                      Margin="0,0,0,10">
            <ItemsControl x:Name="MessagesItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="8,5,8,5" 
                                Padding="12,8,12,8"
                                HorizontalAlignment="{Binding Alignment}"
                                MaxWidth="550"
                                Background="{Binding BubbleColor}">
                            <StackPanel>
                                <TextBlock Text="{Binding Text}" 
                                           Foreground="White" 
                                           TextWrapping="Wrap"
                                           FontSize="14"
                                           LineHeight="20"/>
                                <TextBlock Text="{Binding FormattedTime}" 
                                           Foreground="#888888" 
                                           FontSize="9" 
                                           HorizontalAlignment="Right"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Typing Indicator -->
        <Border x:Name="TypingIndicator" 
                Grid.Row="4" 
                Background="#2D2D2D" 
                Padding="10" 
                Margin="0,0,0,10"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Bot is typing" Foreground="#888888" FontSize="12"/>
                <TextBlock x:Name="TypingDots" Text="..." Foreground="#00D4FF" FontSize="12" FontWeight="Bold" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="5" 
                Background="#2D2D2D" 
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox" 
                         Grid.Column="0"
                         Background="#1E1E1E" 
                         Foreground="White" 
                         BorderBrush="#00D4FF" 
                         BorderThickness="1" 
                         Padding="12"
                         FontSize="14"
                         TextWrapping="Wrap"
                         MinHeight="40"
                         MaxHeight="100"
                         VerticalScrollBarVisibility="Auto"
                         IsEnabled="False"
                         KeyDown="InputTextBox_KeyDown"/>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="Send" 
                        Width="80" 
                        Height="40"
                        Margin="10,0,5,0"
                        IsEnabled="False"
                        Click="SendButton_Click"
                        Background="#0A2E5C"
                        Foreground="White"
                        BorderBrush="#00D4FF"
                        BorderThickness="1"
                        Cursor="Hand"/>

                <Button x:Name="HelpButton" 
                        Grid.Column="2"
                        Content="Help" 
                        Width="80" 
                        Height="40"
                        Margin="5,0,0,0"
                        IsEnabled="False"
                        Click="HelpButton_Click"
                        Background="#1A5F7A"
                        Foreground="White"
                        BorderBrush="#00D4FF"
                        BorderThickness="1"
                        Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>